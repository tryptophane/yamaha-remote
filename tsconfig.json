{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "target": "ES2022",
    "allowJs": true,
    "typeRoots": ["node_modules/@types"],
    "module": "es2020",
    "baseUrl": "./",
    "paths": {
      "stream": ["../node_modules/stream-browserify"]
    },
    "useDefineForClassFields": false,
    "strict": true
  }
}
