{
  "name": "yamaha-remote",
  "version": "0.1.9",
  "license": "MIT",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build --configuration production",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "e2e": "ng e2e",
    "format": "npx prettier 'src/**/*.{js,jsx,ts,tsx,html,css,scss}' --write",
    "prepare": "husky install",
    "pre-commit": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/forms": "^20.3.21",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.21",
    "@angular/platform-browser-dynamic": "^20.3.21",
    "@angular/router": "^20.3.21",
    "@ngrx/effects": "20.1.0",
    "@ngrx/store": "^20.1.0",
    "angular-in-memory-web-api": "^0.20.0",
    "core-js": "~3.49.0",
    "rxjs": "^7.8.0",
    "stream-browserify": "^3.0.0",
    "timers": "^0.1.1",
    "tslib": "^2.5.0",
    "xml2js": "^0.6.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.25",
    "@angular-eslint/builder": "^20.7.0",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/schematics": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/cli": "^20.3.25",
    "@angular/compiler-cli": "^20.3.21",
    "@angular/language-service": "^20.3.21",
    "@types/node": "^18.13.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^8.0.3",
    "lint-staged": "^17.0.4",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": "npm run pre-commit"
  }
}
